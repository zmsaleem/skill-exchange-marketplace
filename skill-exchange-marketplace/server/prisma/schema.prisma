generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  learner
  instructor
  both
  admin
}

enum SkillCategory {
  Programming
  Design
  Music
  Language
  Business
  Science
  Other
}

enum SkillAvailability {
  Weekdays
  Weekends
  Evenings
  Flexible
}

enum BookingStatus {
  pending
  accepted
  rejected
  completed
}

model User {
  id                Int       @id @default(autoincrement())
  name              String
  email             String    @unique
  password          String
  role              UserRole  @default(both)
  bio               String    @default("")
  profilePicture    String    @default("")
  skillsToTeach     String[]  @default([])
  resetToken        String?
  resetTokenExpiry  DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  skills            Skill[]   @relation("InstructorSkills")
  bookingsAsLearner Booking[] @relation("LearnerBookings")
  bookingsAsInstructor Booking[] @relation("InstructorBookings")
  reviewsAsReviewer Review[]  @relation("ReviewerReviews")
  reviewsAsInstructor Review[] @relation("InstructorReviews")
}

model Skill {
  id           Int       @id @default(autoincrement())
  title        String
  description  String
  category     SkillCategory
  availability SkillAvailability
  instructor   User      @relation(fields: [instructorId], references: [id], name: "InstructorSkills")
  instructorId Int
  bookings     Booking[]
  reviews      Review[]
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
}

model Booking {
  id           Int       @id @default(autoincrement())
  skill        Skill     @relation(fields: [skillId], references: [id])
  skillId      Int
  learner      User      @relation("LearnerBookings", fields: [learnerId], references: [id])
  learnerId    Int
  instructor   User      @relation("InstructorBookings", fields: [instructorId], references: [id])
  instructorId Int
  date         DateTime
  status       BookingStatus @default(pending)
  message      String    @default("")
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
}

model Review {
  id           Int       @id @default(autoincrement())
  skill        Skill     @relation(fields: [skillId], references: [id])
  skillId      Int
  reviewer     User      @relation("ReviewerReviews", fields: [reviewerId], references: [id])
  reviewerId   Int
  instructor   User      @relation("InstructorReviews", fields: [instructorId], references: [id])
  instructorId Int
  rating       Int
  comment      String
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
}
